# Optional API keys for cloud LLM providers.
# Copy to .env only if your tooling loads it; the server reads env vars directly.
# On Windows (persistent user env):
#   [Environment]::SetEnvironmentVariable("ANTHROPIC_API_KEY", "sk-ant-...", "User")
#   [Environment]::SetEnvironmentVariable("OLLAMA_API_KEY", "your-key-here", "User")

ANTHROPIC_API_KEY=
OLLAMA_API_KEY=
