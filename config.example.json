{
  "memoryExportPath": "~/UnifiedMemory/memory-exports",
  "claudeCodeLogsPath": "~/.claude/projects",
  "obsidianVaultPath": "~/Documents/ObsidianVault",
  "archivePath": "~/UnifiedMemory/archive",
  "llm": {
    "provider": "ollama",
    "ollama": {
      "baseUrl": "http://localhost:11434",
      "model": "gemma4:e4b",
      "contextWindow": 131072,
      "temperature": 0.3,
      "timeout": 120000
    },
    "ollamaCloud": {
      "baseUrl": "https://ollama.com",
      "apiKey": "env:OLLAMA_API_KEY",
      "model": "gpt-oss:120b",
      "temperature": 0.3,
      "timeout": 120000
    },
    "anthropic": {
      "apiKey": "env:ANTHROPIC_API_KEY",
      "model": "claude-sonnet-4-6",
      "maxTokens": 8000,
      "temperature": 0.3
    }
  },
  "watchEnabled": true,
  "processOnStartup": true,
  "httpBridgeEnabled": true,
  "httpBridgePort": 3001
}
