{
  "name": "unified-memory-mcp",
  "version": "1.0.0",
  "description": "Local MCP server that unifies Claude memory exports, Claude Code logs, and Obsidian notes, then exposes search and summary tools to MCP clients.",
  "type": "module",
  "main": "dist/index.js",
  "license": "MIT",
  "author": "Rajveerx11",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rajveerx11/unified-memory-mcp.git"
  },
  "bugs": "https://github.com/Rajveerx11/unified-memory-mcp/issues",
  "homepage": "https://github.com/Rajveerx11/unified-memory-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "unified-memory",
    "obsidian",
    "claude",
    "claude-code",
    "ollama",
    "personal-knowledge",
    "windows"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
