    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.5.16",
    "chokidar": "^4.0.1",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
